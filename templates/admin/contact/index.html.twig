{% extends "admin/layout.html.twig" %}

{% block content %}
  <div class="row">
    <h1 class="h4 d-flex justify-content-between align-items-center">
      Liste des expériences
      <a href="{{ url("admin_project_create") }}" title="Ajouter un projet" class="btn btn-success btn-sm">
        <i class="bi bi-plus-lg"></i>
      </a>
    </h1>
  </div>
  <div class="">
    <table class="table table-responsive table-card mb-1 w-100">
      <thead>
        <tr>
          <th scope="col">ID</th>
          <th scope="col">Nom</th>
          <th scope="col">Type</th>
          <th scope="col"></th>
        </tr>
      </thead>
      <tbody>
        {% for project in pagination %}
          <tr>
            <th scope="row">{{ project.id }}</th>
            <td>{{ project.name }}</td>
            <td>{{ project.type }}</td>
            <td>
              <a 
                href="{{ path('admin_project_edit', { id : project.id }) }}" 
                class="btn btn-info" 
                title="Modifier le projet chez {{ project.name }}"
              >
                <i class="bi bi-pencil-square"></i>
              </a>
              <a 
                href="{{ path('admin_project_delete', { id : project.id }) }}" 
                class="btn btn-danger" 
                title="Supprimer le projet chez {{ project.name }}"
                onclick="deleteExperience(event);"
              >
                <i class="bi bi-trash"></i>
              </a>
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div> 
  
  <div class="d-flex justify-content-between mt-4">
    <div class="result-infos">
      <span class="fw-bold">{{ numberCurrentResults }}</span>
      sur 
      {{ pagination.getTotalItemCount }} résultats
    </div>
    <div class="pagination-wrap hstack">
      {{ knp_pagination_render(pagination) }}
    </div>
  </div>

{% endblock %}

{% block js %}
  <script src="{{ asset('js/admin/project.js') }}"></script>
{% endblock %}