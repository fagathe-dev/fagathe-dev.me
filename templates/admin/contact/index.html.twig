{% extends "admin/layout.html.twig" %}

{% block content %}
  <div class="row">
    <h1 class="h4">Liste des contacts</h1>
  </div>
  <div class="filter-contact-form">
    {% include "admin/contact/_form_filters.html.twig" %}
  </div>
  <div class="">
    <table class="table table-responsive table-card mb-1 w-100">
      <thead>
        <tr>
          <th scope="col">ID</th>
          <th scope="col">Nom</th>
          <th scope="col">Email</th>
          <th scope="col">Sujet</th>
          <th scope="col">Etat</th>
          <th scope="col"></th>
        </tr>
      </thead>
      <tbody>
        {% for contact in pagination %}
          <tr>
            <th scope="row">{{ contact.id }}</th>
            <td>{{ contact.fullname }}</td>
            <td>{{ contact.email }}</td>
            <td>{{ contact.subject }}</td>
            <td>{{ contact.state }}</td>
            <td>
              <a 
                href="{{ path('admin_contact_edit', { id : contact.id }) }}" 
                class="btn btn-info" 
                title="Modifier le contact chez {{ contact.fullname }}"
              >
                <i class="bi bi-pencil-square"></i>
              </a>
              <a 
                href="{{ path('admin_contact_delete', { id : contact.id }) }}" 
                class="btn btn-danger" 
                title="Supprimer le contact chez {{ contact.fullname }}"
                onclick="deleteExperience(event);"
              >
                <i class="bi bi-trash"></i>
              </a>
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div> 
  
  <div class="d-flex justify-content-between mt-4">
    <div class="result-infos">
      <span class="fw-bold">{{ numberCurrentResults }}</span>
      sur 
      {{ pagination.getTotalItemCount }} résultats
    </div>
    <div class="pagination-wrap hstack">
      {{ knp_pagination_render(pagination) }}
    </div>
  </div>

{% endblock %}

{% block js %}
  <script src="{{ asset('js/admin/contact.js') }}"></script>
{% endblock %}