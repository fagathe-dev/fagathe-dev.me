{% extends "admin/layout.html.twig" %}

{% block content %}
  <div class="row">
    <h1 class="h5 d-flex justify-content-between align-items-center">
      Gestion des balises
      <a href="{{ url("admin_seo_tags_create") }}" title="Ajouter une page" class="btn btn-success btn-sm">
        <i class="bi bi-plus-lg"></i>
      </a>
    </h1>
  </div>
  <div class="">
    <table class="table table-responsive table-card mb-1 w-100">
      <thead>
        <tr>
          <th scope="col">ID</th>
          <th scope="col">Nom</th>
          <th scope="col">Attribut</th>
          <th scope="col">Page</th>
          <th scope="col"></th>
        </tr>
      </thead>
      <tbody>
        {% for tag in seoTags %}
          <tr>
            <th scope="row">{{ tag.id }}</th>
            <td>{{ tag.name }}</td>
            <td>{{ tag.attribute }}</td>
            <td>{{ tag.seo.name }}</td>
            <td>
              <a 
                href="{{ path('admin_seo_tags_edit', { id : tag.id }) }}" 
                class="btn btn-info" 
                title="Modifier la balise {{ tag.name }}"
              >
                <i class="bi bi-pencil-square"></i>
              </a>
              <a 
                href="{{ path('admin_seo_tag_delete', { id : tag.id }) }}" 
                class="btn btn-danger" 
                title="Modifier la balise {{ tag.name }}"
                onclick="deleteSeoTag(event);"
              >
                <i class="bi bi-trash"></i>
              </a>
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
{% endblock %}

{% block js %}
  <script src="{{ asset('js/admin/seo.js') }}"></script>
{% endblock %}